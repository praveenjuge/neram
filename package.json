{
  "name": "neram-monorepo",
  "private": true,
  "version": "0.0.1",
  "license": "MIT",
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "codegen": "turbo run codegen --filter=@neram/convex",
    "deploy": "turbo run deploy --filter=@neram/convex",
    "dev": "turbo run dev",
    "format": "turbo run format",
    "lint": "turbo run lint",
    "preview": "turbo run preview --filter=@neram/web",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "prettier": "^3.9.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "turbo": "^2.10.2"
  }
}
