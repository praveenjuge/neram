{
  "name": "neram",
  "private": false,
  "version": "0.0.5",
  "description": "Workspace-first Neram CLI and MCP server for AI agents.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "neram": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/agent.d.ts",
      "default": "./dist/agent.js"
    },
    "./auth": {
      "types": "./dist/auth.d.ts",
      "default": "./dist/auth.js"
    },
    "./mcp": {
      "types": "./dist/mcp.d.ts",
      "default": "./dist/mcp.js"
    }
  },
  "files": [
    "dist/*.js",
    "dist/*.d.ts",
    "dist/*.d.ts.map",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/praveenjuge/neram.git",
    "directory": "apps/agent"
  },
  "bugs": {
    "url": "https://github.com/praveenjuge/neram/issues"
  },
  "homepage": "https://neram.praveenjuge.com/docs",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "bun build ./src/cli.ts --outdir ./dist --target=node --packages external && bun build ./src/agent.ts ./src/auth.ts ./src/mcp.ts --outdir ./dist --target=node --packages external && tsc --emitDeclarationOnly -p tsconfig.build.json && chmod +x ./dist/cli.js",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "lint": "eslint .",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@napi-rs/keyring": "^1.3.0",
    "commander": "^15.0.0",
    "convex": "^1.41.0",
    "open": "^11.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10",
    "@types/node": "^24",
    "eslint": "^10",
    "globals": "^17",
    "typescript": "~6",
    "typescript-eslint": "^8",
    "vitest": "^4.1.9"
  }
}
