{
  "expo": {
    "name": "Neram",
    "slug": "neram-native",
    "version": "1.0.0",
    "platforms": ["ios"],
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "neram",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.praveenjuge.neram",
      "supportsTablet": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#F7F7F8",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 96,
          "dark": {
            "backgroundColor": "#151718",
            "image": "./assets/images/splash-icon.png"
          }
        }
      ],
      "@clerk/expo",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": false,
      "reactCompiler": true
    }
  }
}
