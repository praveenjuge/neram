{
  "framework": "vite",
  "installCommand": "bun install --frozen-lockfile",
  "buildCommand": "bun run deploy",
  "outputDirectory": "apps/web/dist",
  "rewrites": [
    {
      "source": "/mcp",
      "destination": "/api/mcp"
    },
    {
      "source": "/.well-known/neram-agent.json",
      "destination": "/api/agent-config"
    },
    {
      "source": "/((?!mcp$)(?!.*\\..*).*)",
      "destination": "/index.html"
    }
  ]
}
